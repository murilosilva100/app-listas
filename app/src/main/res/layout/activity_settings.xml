<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/notes_background"
    tools:context=".SettingsActivity">

    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_note"
            app:tint="@color/notes_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="App de notas"
            android:textColor="@color/notes_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:id="@+id/headerDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#3A2553"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerContainer" />

    <TextView
        android:id="@+id/settingsTitle"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="Configuracoes"
        android:textColor="@color/notes_text"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerDivider" />

    <LinearLayout
        android:id="@+id/settingsCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_note_card"
        android:orientation="vertical"
        android:padding="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/settingsTitle">

        <LinearLayout
            android:id="@+id/themeRow"
            style="@style/SettingsRow">

            <TextView
                style="@style/SettingsRowLabel"
                android:text="Definir tema" />

            <TextView
                android:id="@+id/themeValue"
                style="@style/SettingsRowValue"
                tools:text="Claro" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/fontSizeRow"
            style="@style/SettingsRow"
            android:layout_marginTop="8dp">

            <TextView
                style="@style/SettingsRowLabel"
                android:text="Tamanho dos textos" />

            <TextView
                android:id="@+id/fontSizeValue"
                style="@style/SettingsRowValue"
                tools:text="16px" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/syncRow"
            style="@style/SettingsRow"
            android:layout_marginTop="8dp">

            <TextView
                style="@style/SettingsRowLabel"
                android:text="Sincronizar na nuvem" />

            <TextView
                android:id="@+id/syncValue"
                style="@style/SettingsRowValue"
                android:drawableTop="@drawable/ic_cloud_sync"
                android:drawablePadding="0dp"
                app:drawableTint="@color/notes_text" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomArea"
        android:layout_width="0dp"
        android:layout_height="88dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/bottomNavigation"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:background="@drawable/bg_bottom_bar"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="6dp">

            <ImageButton
                android:id="@+id/navHome"
                style="@style/BottomNavButton"
                android:contentDescription="Tela inicial"
                android:src="@drawable/ic_home" />

            <ImageButton
                android:id="@+id/navChecklist"
                style="@style/BottomNavButton"
                android:layout_marginStart="10dp"
                android:contentDescription="Checklists"
                android:src="@drawable/ic_checklist" />

            <ImageButton
                android:id="@+id/navSettings"
                style="@style/BottomNavButton"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_nav_selected"
                android:contentDescription="Configuracoes"
                android:src="@drawable/ic_settings" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/addNoteButton"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="18dp"
            android:background="@drawable/bg_add_button"
            android:contentDescription="Adicionar nota"
            android:padding="17dp"
            android:src="@drawable/ic_add"
            app:tint="@color/notes_text" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
