<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/checklistCard"
    android:layout_width="match_parent"
    android:layout_height="96dp"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_note_card"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:padding="14dp">

    <CheckBox
        android:id="@+id/checklistDone"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:buttonTint="@color/notes_primary"
        android:contentDescription="Marcar checklist"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/editChecklistButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Editar checklist"
        android:padding="8dp"
        android:src="@drawable/ic_edit"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/notes_text_muted" />

    <TextView
        android:id="@+id/checklistTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="@color/notes_text"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/editChecklistButton"
        app:layout_constraintStart_toEndOf="@id/checklistDone"
        app:layout_constraintTop_toTopOf="@id/checklistDone" />

    <TextView
        android:id="@+id/checklistPriority"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:textColor="@color/notes_text_disabled"
        android:textSize="11sp"
        app:layout_constraintEnd_toStartOf="@id/editChecklistButton"
        app:layout_constraintStart_toEndOf="@id/checklistDone"
        app:layout_constraintTop_toBottomOf="@id/checklistTitle" />

    <TextView
        android:id="@+id/checklistStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:textColor="@color/notes_text_disabled"
        android:textSize="11sp"
        app:layout_constraintEnd_toStartOf="@id/editChecklistButton"
        app:layout_constraintStart_toEndOf="@id/checklistDone"
        app:layout_constraintTop_toBottomOf="@id/checklistPriority" />
</androidx.constraintlayout.widget.ConstraintLayout>
